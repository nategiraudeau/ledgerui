{
  "name": "@nategiraudeau/ledgerui",
  "version": "0.0.2-alpha.0",
  "description": "minimal react + scss ui kit. solarized palette, monospace, cmd+d theme toggle.",
  "author": "Nate Giraudeau",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nategiraudeau/ledgerui.git"
  },
  "license": "MIT",
  "type": "module",
  "sideEffects": [
    "**/*.css",
    "**/*.scss"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "style": "./dist/styles.css",
  "sass": "./src/styles/index.scss",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/styles.css",
    "./scss": "./src/styles/index.scss",
    "./scss/*": "./src/styles/*"
  },
  "files": [
    "dist",
    "src/styles"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build:js": "tsc --noEmit && vite build",
    "build:css": "sass --no-source-map src/styles/index.scss dist/styles.css",
    "build": "bun run clean && bun run build:js && bun run build:css",
    "prepublishOnly": "bun run build",
    "publish:npm": "npm publish --access public",
    "publish:npm:alpha": "npm publish --access public --tag alpha",
    "dev": "vite build --watch",
    "example": "cd example && bun install && bun run dev",
    "example:build": "cd example && bun install && bun run build"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react-swc": "^3.10.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "sass": "^1.89.2",
    "typescript": "^5.8.3",
    "vite": "^7.1.3",
    "vite-plugin-dts": "^4.5.4"
  },
  "keywords": [
    "react",
    "ui",
    "scss",
    "components",
    "solarized",
    "monospace"
  ]
}
